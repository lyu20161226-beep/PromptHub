NEXT_PUBLIC_SITE_URL=http://localhost:3000
# DeepSeek API Key must be the real key that starts with sk-
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# Model name is not an API key. Keep it as deepseek-chat unless you intentionally change models.
DEEPSEEK_MODEL=deepseek-chat
# Optional but recommended in production for cross-instance rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
